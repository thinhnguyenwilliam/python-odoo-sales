<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rule: Nhân viên chỉ xem đơn hàng của mình -->
    <record id="sale_order_rule_own_records" model="ir.rule">
        <field name="name">Sale: Own Sale Orders Only</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Record Rule: Manager xem tất cả -->
    <record id="sale_order_rule_manager_all" model="ir.rule">
        <field name="name">Sale: Manager See All Orders</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
