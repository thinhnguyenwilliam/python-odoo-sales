<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- REPORT ACTION — In Đơn Hàng PDF                                     -->
    <!-- ================================================================== -->
    <record id="action_report_sale_order_custom" model="ir.actions.report">
        <field name="name">Đơn Hàng Bán (Custom)</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_management_custom.report_sale_order_document</field>
        <field name="report_file">sale_management_custom.report_sale_order_document</field>
        <field name="print_report_name">'Đơn Hàng - %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_a4"/>
    </record>
</odoo>
