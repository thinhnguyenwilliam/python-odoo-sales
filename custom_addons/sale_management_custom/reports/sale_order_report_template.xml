<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- QWEB TEMPLATE — Đơn Hàng PDF                                        -->
    <!-- ================================================================== -->
    <template id="report_sale_order_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- HEADER -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h2 class="text-primary">
                                    <strong>ĐƠN HÀNG BÁN</strong>
                                </h2>
                                <h4><t t-esc="o.name"/></h4>
                                <t t-if="o.internal_code">
                                    <p class="text-muted">
                                        Mã nội bộ: <strong><t t-esc="o.internal_code"/></strong>
                                    </p>
                                </t>
                            </div>
                            <div class="col-6 text-right">
                                <!-- Trạng thái duyệt badge -->
                                <t t-if="o.approval_state == 'approved'">
                                    <span class="badge badge-success" style="font-size:14px; padding:8px 16px;">
                                        ✅ ĐÃ PHÊ DUYỆT
                                    </span>
                                </t>
                                <t t-elif="o.approval_state == 'pending'">
                                    <span class="badge badge-warning" style="font-size:14px; padding:8px 16px;">
                                        ⏳ CHỜ DUYỆT
                                    </span>
                                </t>
                                <t t-elif="o.approval_state == 'rejected'">
                                    <span class="badge badge-danger" style="font-size:14px; padding:8px 16px;">
                                        ❌ BỊ TỪ CHỐI
                                    </span>
                                </t>
                                <br/>
                                <p class="mt-2">
                                    Ngày: <strong><t t-esc="o.date_order" t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/></strong>
                                </p>
                            </div>
                        </div>

                        <hr/>

                        <!-- THÔNG TIN HAI BÊN -->
                        <div class="row mb-4">
                            <!-- Bên bán -->
                            <div class="col-6">
                                <h5 class="text-muted">BÊN BÁN</h5>
                                <p>
                                    <strong><t t-esc="o.company_id.name"/></strong><br/>
                                    <t t-esc="o.company_id.street"/><br/>
                                    <t t-if="o.company_id.phone">
                                        📞 <t t-esc="o.company_id.phone"/><br/>
                                    </t>
                                    <t t-if="o.company_id.email">
                                        ✉️ <t t-esc="o.company_id.email"/>
                                    </t>
                                </p>
                            </div>
                            <!-- Bên mua -->
                            <div class="col-6">
                                <h5 class="text-muted">BÊN MUA</h5>
                                <p>
                                    <strong><t t-esc="o.partner_id.name"/></strong><br/>
                                    <t t-esc="o.partner_id.street"/><br/>
                                    <t t-if="o.partner_id.phone">
                                        📞 <t t-esc="o.partner_id.phone"/><br/>
                                    </t>
                                    <t t-if="o.partner_id.email">
                                        ✉️ <t t-esc="o.partner_id.email"/>
                                    </t>
                                </p>
                            </div>
                        </div>

                        <!-- THÔNG TIN PHÒNG BAN & ƯU TIÊN -->
                        <t t-if="o.department_id or o.priority_level != 'normal'">
                            <div class="row mb-3">
                                <div class="col-12">
                                    <table class="table table-sm table-bordered">
                                        <tr style="background-color:#f8f9fa;">
                                            <t t-if="o.department_id">
                                                <td><strong>Phòng Ban:</strong></td>
                                                <td><t t-esc="o.department_id.name"/></td>
                                            </t>
                                            <td><strong>Nhân Viên:</strong></td>
                                            <td><t t-esc="o.user_id.name"/></td>
                                            <td><strong>Mức Ưu Tiên:</strong></td>
                                            <td>
                                                <t t-if="o.priority_level == 'urgent'">🔴 Khẩn Cấp</t>
                                                <t t-elif="o.priority_level == 'high'">🟡 Cao</t>
                                                <t t-else="">🟢 Bình Thường</t>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </t>

                        <!-- BẢNG SẢN PHẨM -->
                        <h5 class="text-primary">CHI TIẾT SẢN PHẨM</h5>
                        <table class="table table-sm table-bordered o_main_table">
                            <thead style="background-color:#007bff; color:white;">
                                <tr>
                                    <th class="text-center" style="width:5%">#</th>
                                    <th style="width:35%">Sản Phẩm</th>
                                    <th class="text-center" style="width:10%">ĐVT</th>
                                    <th class="text-right" style="width:10%">SL</th>
                                    <th class="text-right" style="width:15%">Đơn Giá</th>
                                    <th class="text-right" style="width:8%">CK%</th>
                                    <th class="text-right" style="width:17%">Thành Tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.order_line" t-as="line">
                                    <tr>
                                        <td class="text-center"><t t-esc="line_index + 1"/></td>
                                        <td>
                                            <strong><t t-esc="line.product_id.name"/></strong>
                                            <t t-if="line.name and line.name != line.product_id.name">
                                                <br/><small class="text-muted"><t t-esc="line.name"/></small>
                                            </t>
                                        </td>
                                        <td class="text-center"><t t-esc="line.product_uom.name"/></td>
                                        <td class="text-right"><t t-esc="line.product_uom_qty" t-options='{"widget": "float", "precision": 2}'/></td>
                                        <td class="text-right">
                                            <t t-esc="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                        <td class="text-right">
                                            <t t-if="line.discount">
                                                <t t-esc="line.discount"/>%
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                        <td class="text-right">
                                            <t t-esc="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- TỔNG TIỀN -->
                        <div class="row">
                            <div class="col-6">
                                <!-- Ghi chú -->
                                <t t-if="o.note">
                                    <h6>Ghi Chú:</h6>
                                    <p class="text-muted"><t t-esc="o.note"/></p>
                                </t>
                                <!-- Thông tin phê duyệt -->
                                <t t-if="o.approval_state == 'approved' and o.approver_id">
                                    <div style="background:#d4edda; padding:10px; border-radius:5px;">
                                        <small>
                                            ✅ Đã duyệt bởi: <strong><t t-esc="o.approver_id.name"/></strong><br/>
                                            Ngày duyệt: <t t-esc="o.approval_date" t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/>
                                        </small>
                                    </div>
                                </t>
                                <t t-if="o.approval_state == 'rejected'">
                                    <div style="background:#f8d7da; padding:10px; border-radius:5px;">
                                        <small>
                                            ❌ Từ chối bởi: <strong><t t-esc="o.approver_id.name"/></strong><br/>
                                            Lý do: <t t-esc="o.rejection_reason"/>
                                        </small>
                                    </div>
                                </t>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm" style="margin-left:auto;">
                                    <tr>
                                        <td>Tạm Tính:</td>
                                        <td class="text-right">
                                            <t t-esc="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                    <t t-if="o.total_discount_amount">
                                        <tr class="text-danger">
                                            <td>Tổng Chiết Khấu:</td>
                                            <td class="text-right">
                                                -<t t-esc="o.total_discount_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr>
                                        <td>Thuế:</td>
                                        <td class="text-right">
                                            <t t-esc="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr style="background-color:#007bff; color:white; font-size:16px;">
                                        <td><strong>TỔNG CỘNG:</strong></td>
                                        <td class="text-right">
                                            <strong>
                                                <t t-esc="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </strong>
                                        </td>
                                    </tr>
                                </table>
                                <t t-if="o.total_weight">
                                    <p class="text-muted text-right">
                                        <small>Tổng trọng lượng: <t t-esc="o.total_weight"/> kg</small>
                                    </p>
                                </t>
                            </div>
                        </div>

                        <!-- ĐIỀU KHOẢN THANH TOÁN -->
                        <t t-if="o.payment_term_id">
                            <div class="row mt-3">
                                <div class="col-12">
                                    <strong>Điều Khoản Thanh Toán:</strong>
                                    <t t-esc="o.payment_term_id.name"/>
                                </div>
                            </div>
                        </t>

                        <!-- KHU VỰC CHỮ KÝ -->
                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <p><strong>ĐẠI DIỆN BÊN BÁN</strong></p>
                                <p class="text-muted"><em>(Ký, ghi rõ họ tên)</em></p>
                                <br/><br/><br/>
                                <p>................................</p>
                            </div>
                            <div class="col-6 text-center">
                                <p><strong>ĐẠI DIỆN BÊN MUA</strong></p>
                                <p class="text-muted"><em>(Ký, ghi rõ họ tên)</em></p>
                                <br/><br/><br/>
                                <p>................................</p>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
