<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- FORM VIEW - Sale Order                                               -->
    <!-- ================================================================== -->
    <record id="view_sale_order_form_custom" model="ir.ui.view">
        <field name="name">sale.order.form.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Thêm statusbar approval vào đầu -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_state" widget="statusbar"
                       statusbar_visible="pending,approved,rejected"
                       attrs="{'invisible': [('state', 'not in', ['sale', 'done'])]}"/>
            </xpath>

            <!-- Thêm button Approve/Reject vào header -->
            <xpath expr="//button[@name='action_confirm']" position="after">
                <button name="action_approve"
                        string="✅ Phê Duyệt"
                        type="object"
                        class="btn-success"
                        groups="sales_team.group_sale_manager"
                        attrs="{'invisible': [('approval_state', '!=', 'pending'), ('state', 'not in', ['sale'])]}"/>
                <button name="action_reject"
                        string="❌ Từ Chối"
                        type="object"
                        class="btn-danger"
                        groups="sales_team.group_sale_manager"
                        attrs="{'invisible': [('approval_state', '!=', 'pending'), ('state', 'not in', ['sale'])]}"/>
                <button name="action_reset_to_pending"
                        string="🔄 Reset Duyệt"
                        type="object"
                        groups="sales_team.group_sale_manager"
                        attrs="{'invisible': [('approval_state', 'not in', ['rejected'])]}"/>
            </xpath>

            <!-- Thêm tab Thông Tin Nội Bộ -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="📋 Thông Tin Nội Bộ" name="internal_info">
                    <group>
                        <group string="Phê Duyệt">
                            <field name="internal_code"/>
                            <field name="approval_state"/>
                            <field name="approver_id"/>
                            <field name="approval_date"/>
                            <field name="rejection_reason"
                                   attrs="{'invisible': [('approval_state', '!=', 'rejected')]}"/>
                        </group>
                        <group string="Phân Loại">
                            <field name="priority_level"/>
                            <field name="department_id"
                                   options="{'no_create': True}"/>
                            <field name="total_discount_amount"/>
                            <field name="total_weight"/>
                        </group>
                    </group>
                    <group string="Ghi Chú Nội Bộ">
                        <field name="note_internal" nolabel="1" placeholder="Ghi chú nội bộ..."/>
                    </group>
                </page>
            </xpath>

            <!-- Thêm cột Biên LN vào order_line -->
            <xpath expr="//field[@name='order_line']/tree//field[@name='price_subtotal']" position="after">
                <field name="margin_percent" optional="show" string="% Biên LN"
                       decoration-danger="margin_percent &lt; 0"
                       decoration-warning="margin_percent &lt; 10"/>
            </xpath>

        </field>
    </record>

    <!-- ================================================================== -->
    <!-- LIST VIEW - Sale Order                                               -->
    <!-- ================================================================== -->
    <record id="view_sale_order_tree_custom" model="ir.ui.view">
        <field name="name">sale.order.tree.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_state"
                       decoration-success="approval_state == 'approved'"
                       decoration-danger="approval_state == 'rejected'"
                       decoration-warning="approval_state == 'pending'"/>
                <field name="is_overdue"
                       decoration-danger="is_overdue == True"
                       optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- SEARCH VIEW - Sale Order                                             -->
    <!-- ================================================================== -->
    <record id="view_sale_order_search_custom" model="ir.ui.view">
        <field name="name">sale.order.search.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_sale_orders_filter']" position="after">
                <!-- Filters theo approval state -->
                <separator/>
                <filter name="filter_pending_approval"
                        string="⏳ Chờ Duyệt"
                        domain="[('approval_state', '=', 'pending'), ('state', '=', 'sale')]"/>
                <filter name="filter_approved"
                        string="✅ Đã Duyệt"
                        domain="[('approval_state', '=', 'approved')]"/>
                <filter name="filter_rejected"
                        string="❌ Từ Chối"
                        domain="[('approval_state', '=', 'rejected')]"/>
                <filter name="filter_overdue"
                        string="⚠️ Quá Hạn"
                        domain="[('is_overdue', '=', True)]"/>
                <separator/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter name="group_by_approval_state"
                        string="Trạng Thái Duyệt"
                        context="{'group_by': 'approval_state'}"/>
                <filter name="group_by_priority"
                        string="Mức Độ Ưu Tiên"
                        context="{'group_by': 'priority_level'}"/>
                <filter name="group_by_department"
                        string="Phòng Ban"
                        context="{'group_by': 'department_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- ACTION - Danh sách chờ duyệt                                        -->
    <!-- ================================================================== -->
    <record id="action_sale_orders_pending_approval" model="ir.actions.act_window">
        <field name="name">Đơn Hàng Chờ Duyệt</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('approval_state', '=', 'pending'), ('state', '=', 'sale')]</field>
        <field name="context">{'search_default_filter_pending_approval': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Không có đơn hàng nào đang chờ duyệt!
            </p>
        </field>
    </record>
</odoo>
