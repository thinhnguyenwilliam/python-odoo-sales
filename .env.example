# ============================================================
#  Odoo 17 — Production Environment Variables
#  COPY file này thành .env và điền giá trị thực
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=odoo_prod
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_2024!

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_2024!

# ── Odoo ─────────────────────────────────────────────────────
ODOO_ADMIN_PASSWD=CHANGE_ME_master_password_2024!

# ── Domain / SSL ─────────────────────────────────────────────
DOMAIN=erp.yourdomain.com
